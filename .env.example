# Copier ce fichier en .env et renseigner les valeurs

# --- AWS (Nova Sonic + Bedrock) ---
# Exporter via : eval $(aws configure export-credentials --format env)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-east-1   # Nova Sonic est en us-east-1

# --- Twilio (appels sortants) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=            # Numéro Twilio source (E.164, ex: +14155238886)

# --- Bridge Nova Sonic ---
NOVA_VOICE=matthew              # Voix Nova Sonic (matthew | tiffany)
BRIDGE_PORT=8080                # Port local du bridge
BRIDGE_BASE_URL=                # URL publique ngrok (auto-détecté si vide)
# BRIDGE_WS_URL auto-dérivé de BRIDGE_BASE_URL

# --- AWS Connect (mode Polly — fallback) ---
CONNECT_INSTANCE_ID=b6a9e127-7f71-435c-80e8-ffb833f141c2
CONTACT_FLOW_ID=82615716-f594-489a-958a-83a839afe2d1
CONNECT_SOURCE_PHONE=+442046399586

# --- Démo ---
CALL_TIMEOUT=180               # Secondes max d'attente fin d'appel (mode nova-sonic)
